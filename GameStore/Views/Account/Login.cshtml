<style>
    input:focus {
        outline: none !important;
    }
</style>

<form method="post">
    <div style="width: 300px;">
        <div class="bg-dark p-1" style="width: 100%;">
            <p class="fw-semibold steam-light-green-text mb-0">Account information</p>
        </div>
        <div class="steam-dark-green p-1 ">
            <input name="email" placeholder="Email" required class="steam-grey-text" />
            <input name="password" type="password" placeholder="Password" required class="steam-grey-text" />
        </div>
        <div asp-validation-summary="All" class="text-danger"></div>
        <button type="submit" class="win2k-btn" style="outline:none">Login</button>
        
    </div>
</form>