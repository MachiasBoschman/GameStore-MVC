@model List<GameStore.Models.Game>
@{
    ViewData["Title"] = "Index";
}

<h3>Index</h3>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Steam App Id</th>
            <th>Platform</th>
            <th>Distributor</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var game in Model)
        {
            <tr>
                <td>@game.Name</td>
                <td>@game.Price?.ToString("N2")$</td>
                <td>
                    @if(game.SteamApp?.Id != null)
                    {
                        @game.SteamApp.Id
                    }
                    else
                    {
                        <i class="bi bi-slash-circle-fill text-danger"></i>
                    }
                </td>
                <td>
                    @string.Join(", ", game.Platforms.Select(p => p.Name))
                </td>
                <td>
                    @string.Join(", ", game.Distributors.Select(d => d.Name))
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@game.Id">Edit</a>
                    <a asp-action="Delete" asp-route-id="@game.Id">Delete</a>
                </td> 
            </tr>
        }
    </tbody>
</table>