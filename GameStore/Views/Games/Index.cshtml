@model List<GameStore.Models.Game>
@{
    ViewData["Title"] = "Index";
}
@inject Microsoft.AspNetCore.Identity.SignInManager<Microsoft.AspNetCore.Identity.IdentityUser> SignInManager
<!-- PAGE HEADING -->
<div class="my-4 steam-background-wrapper p-steam-bgwrapper">
    <h1 class="steam-white-text">Game Library</h1>
    <h6 class="steam-white-text">
        <span class="steam-grey-text">In minutes, </span>
        you'll be playing your favorite games
    </h6>
    <div class="black-box"></div>
    <p class="steam-grey-text col-12 col-md-10 col-lg-8 ">
        Below you will find your favorite collection of titles, including recent titles and all-time favorites. <br />
        We are constantly working on the Steam client to optimize performance and ensure your gaming experience remains seamless. <br />
        Check back often for updates on your favorite franchises and new additions to the store.
    </p>
    <hr class="col-12 col-md-10 col-lg-8 " />
    <!-- CREATE NEW GAME CARD -->
    <a asp-action="Create" class="col-12 col-md-10 col-lg-8 card card-game steam-dark-green steam-white-text black-gradient-right-to-left d-flex align-items-center justify-content-center" style="max-height: 120px; text-decoration: none;">
        <i class="bi bi-plus-lg" style="font-size: clamp(2rem, 10vw, 4rem); color: #bfba4f;"></i>
    </a>
    @foreach (var game in Model)
    {
        <div class="col-12 col-md-10 col-lg-8  card card-game steam-dark-green steam-white-text black-gradient-right-to-left"
             onclick="location.href='@Url.Action("Overview", new { id = game.Id })'">
            <div class="row g-0">
                <!-- THUMBNAIL -->
                <img src="@(game.ImagePath ?? "https://placehold.co/148x84")" class="card-game-thumbnail" />
                <!-- CARD BODY -->
                <div class="col d-flex align-items-center px-2 gap-3 card-main-body">
                    <!-- NAME, PLATFORM, TAGS -->
                    <div class="flex-grow-1 min-width-0 d-flex flex-column">
                        <p class="mb-0 price h6">@game.Name</p>
                        <div class="d-flex gap-2">
                            @foreach (var platform in game.Platforms)
                            {
                                var iconClass = platform.Name switch
                                {
                                    "PC" => "bi-microsoft",
                                    "Playstation" => "bi-playstation",
                                    "Xbox" => "bi-xbox",
                                    _ => "bi-device-hdd"
                                };

                                <i class="bi @iconClass steam-grey-text" title="@platform.Name"></i>
                            }
                        </div>
                        <small class="steam-green-text">@string.Join(", ", game.Genres.Select(g => g.Name))</small>
                    </div>
                    <!-- PRICING -->
                    <div class="ms-auto d-flex flex-shrink-0 flex-column align-items-end min-width-250">
                        @* <p class="mb-0 me-2 text-end text-decoration-line-through steam-green-text">$69,99</p> *@
                        <p class="h5 mb-0 me-2 price">@game.Price.ToString("C2")</p>
                    </div>
                </div>
                @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                {
                    <!-- ACTION PANELS -->
                    <div class="card-action-wrapper">
                        <!-- EDIT PANEL -->
                        <a asp-action="Edit" asp-route-id="@game.Id" 
                        class="card-action-panel steam-dark-green d-flex align-items-center justify-content-center"
                               onclick="event.stopPropagation();">
                            <i class="bi bi-wrench-adjustable card-action-icon"></i>
                        </a>
                        <!-- DELETE PANEL -->
                        <button type="button"
                                class="card-action-panel steam-dark-green card-delete-panel d-flex align-items-center justify-content-center"
                                onclick="event.stopPropagation(); openDeleteDialog(@game.Id, '@Html.Raw(game.Name.Replace("'", "\\'"))')">
                            <i class="bi bi-trash3 card-action-icon card-delete-icon"></i>
                        </button>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- ══════════════════════════════════════════
     WIN2K DELETE DIALOG
     ══════════════════════════════════════════ -->
<div id="win2k-overlay" onclick="closeDeleteDialog()" style="display:none;"></div>

<div id="win2k-dialog" role="dialog" aria-modal="true" aria-labelledby="win2k-title" style="display:none;">

    <!-- Dialog Body -->
    <div id="win2k-body">
        <div id="win2k-message-area">
            <p id="win2k-question">Would you like to delete this game from the library?</p>
            <p id="win2k-game-name"></p>
        </div>
    </div>

    <!-- Separator -->
    <div id="win2k-separator"></div>

    <!-- Buttons -->
    <div id="win2k-buttons">
        <form id="win2k-delete-form" asp-action="Delete" method="post">
            <input type="hidden" id="win2k-game-id" name="id" value="" />
            @Html.AntiForgeryToken()
            <button type="submit" class="win2k-btn">Delete</button>
        </form>
        <button type="button" class="win2k-btn" id="win2k-confirm-btn" onclick="closeDeleteDialog()">Cancel</button>
    </div>
</div>

@section Scripts {
    <script>
        function openDeleteDialog(gameId, gameName) {
            document.getElementById('win2k-game-id').value = gameId;
            document.getElementById('win2k-game-name').textContent = '"' + gameName + '"';
            document.getElementById('win2k-overlay').style.display = 'block';
            document.getElementById('win2k-dialog').style.display = 'flex';
            // Focus the Cancel button by default (safer UX, classic Windows behaviour)
            document.getElementById('win2k-confirm-btn').focus();
        }

        function closeDeleteDialog() {
            document.getElementById('win2k-overlay').style.display = 'none';
            document.getElementById('win2k-dialog').style.display = 'none';
        }

        // Close on Escape key
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeDeleteDialog();
        });
    </script>
}