@model GameStore.Models.Game
<!-- PAGE HEADING -->
<div class="my-4 steam-background-wrapper p-steam-bgwrapper">
    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <h1 class="steam-white-text"><span class="steam-grey-text">Over</span>view</h1>
            <div class="black-box"></div>
            <hr class="w-100" />
            <div class="card card-game steam-dark-green steam-white-text black-gradient-right-to-left">
                <div class="row g-0">
                    <!-- THUMBNAIL -->
                    <img src="@(Model.ImagePath ?? "https://placehold.co/148x84")" class="card-game-thumbnail" />
                    <!-- CARD BODY -->
                    <div class="col d-flex align-items-center px-2 gap-3 card-main-body">
                        <!-- NAME, PLATFORM, TAGS -->
                        <div class="flex-grow-1 min-width-0 d-flex flex-column">
                            <p class="mb-0 price h6">@Model.Name</p>
                            <div class="d-flex gap-2">
                                @foreach (var platform in Model.Platforms)
                                {
                                    var iconClass = platform.Name switch
                                    {
                                        "PC" => "bi-microsoft",
                                        "Playstation" => "bi-playstation",
                                        "Xbox" => "bi-xbox",
                                        _ => "bi-device-hdd"
                                    };

                                    <i class="bi @iconClass steam-grey-text" title="@platform.Name"></i>
                                }
                            </div>
                            <small class="steam-green-text">@string.Join(", ", Model.Genres.Select(g => g.Name))</small>
                        </div>
                        <!-- PRICING -->
                        <div class="ms-auto d-flex flex-shrink-0 flex-column align-items-end min-width-250">
                            <p class="h5 mb-0 me-2 price">@Model.Price.ToString("C2")</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="my-4">
                <h6 class="steam-grey-text">
                    Description
                </h6>
                <div class="black-box"></div>
                <p class="steam-grey-text">
                    @(Model.Description ?? "No description available for this game.")
                </p>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="h-100 steam-darker-green overflow-hidden ">

                <div class="bg-dark p-2">
                    <p class="fw-semibold steam-light-green-text mb-0">Game Information</p>
                </div>
                <div class="p-2">
                    <div class="mb-4">
                        <p class="steam-white-text fw-semibold mb-1">Available On</p>
                        <div class="d-flex gap-2">
                            @foreach (var platform in Model.Platforms)
                            {
                                var iconClass = platform.Name switch
                                {
                                    "PC" => "bi-microsoft",
                                    "Playstation" => "bi-playstation",
                                    "Xbox" => "bi-xbox",
                                    _ => "bi-device-hdd"
                                };
                                <span title="@platform.Name" class="steam-grey-text">
                                    <i class="bi @iconClass"></i> @platform.Name
                                </span>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <p class="steam-white-text fw-semibold mb-1">Genre</p>
                        <p class="steam-grey-text">
                            @string.Join(", ", Model.Genres.Select(g => g.Name))
                        </p>
                    </div>

                    <div>
                        <p class="steam-white-text fw-semibold mb-1">Price</p>
                        <p class="price h5">@Model.Price.ToString("C2")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>